# Copy this file to .env and fill in values, or run ./generate-env.sh

# Database
IMMICH_DB_USERNAME=immich
IMMICH_DB_PASSWORD=changeme
IMMICH_DB_DATABASE_NAME=immich

# Connection strings — don't change these unless you rename the containers
IMMICH_DB_URL=postgresql://${IMMICH_DB_USERNAME}:${IMMICH_DB_PASSWORD}@immich-postgres/${IMMICH_DB_DATABASE_NAME}
IMMICH_REDIS_HOSTNAME=immich-redis
