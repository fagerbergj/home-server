# Root secrets — copy to .env and fill in values, then run per-service generate-env.sh scripts
# cp .env.example .env

# ---------------------------------------------------------------------------
# Gmail (RAID alerts and disk usage emails)
# https://myaccount.google.com/apppasswords
# ---------------------------------------------------------------------------
export GMAIL_APP_PASSWORD=your-app-password-here

# ---------------------------------------------------------------------------
# qBittorrent / Mullvad VPN (Gluetun)
# Generate a WireGuard key at https://mullvad.net/en/account/devices
# ---------------------------------------------------------------------------
export WIREGUARD_PRIVATE_KEY=your-wireguard-private-key-here

# ---------------------------------------------------------------------------
# Photos (Immich) — auto-generated by photos/generate-env.sh
# ---------------------------------------------------------------------------
export DB_PASSWORD=
export DB_USERNAME=immich
export DB_DATABASE_NAME=immich
export DB_URL=
export REDIS_HOSTNAME=immich-redis

# ---------------------------------------------------------------------------
# LLM (Ollama / Open WebUI) — auto-generated by llm/generate-env.sh
# ---------------------------------------------------------------------------
export OLLAMA_API_KEY=
