# Root secrets — copy to .env and fill in values, then run per-service generate-env.sh scripts
# cp .env.example .env

# ---------------------------------------------------------------------------
# Gmail (RAID alerts and disk usage emails)
# https://myaccount.google.com/apppasswords
# ---------------------------------------------------------------------------
GMAIL_APP_PASSWORD=your-app-password-here

# ---------------------------------------------------------------------------
# Plex
# One-time claim token to link the server to your plex.tv account.
# Get it from https://plex.tv/claim — expires in 4 minutes.
# Only needed on first start; leave blank after the server is claimed.
# ---------------------------------------------------------------------------
PLEX_CLAIM=claim-xxxxxxxxxxxxxxxxxxxx

# ---------------------------------------------------------------------------
# qBittorrent / Mullvad VPN (Gluetun)
# Generate a WireGuard key at https://mullvad.net/en/account/wireguard-keys
# ---------------------------------------------------------------------------
WIREGUARD_PRIVATE_KEY=your-wireguard-private-key-here
WIREGUARD_ADDRESSES=10.x.x.x/32

# ---------------------------------------------------------------------------
# Photos (Immich) — auto-generated by photos/generate-env.sh
# ---------------------------------------------------------------------------
DB_PASSWORD=
DB_USERNAME=immich
DB_DATABASE_NAME=immich
DB_URL=
REDIS_HOSTNAME=immich-redis

# ---------------------------------------------------------------------------
# LLM (Ollama / Open WebUI) — auto-generated by llm/generate-env.sh
# ---------------------------------------------------------------------------
OLLAMA_API_KEY=
